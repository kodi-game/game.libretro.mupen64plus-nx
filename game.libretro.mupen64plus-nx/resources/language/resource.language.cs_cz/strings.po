msgctxt "Addon Summary"
msgid "Nintendo - Nintendo 64 (Mupen64Plus-Next)"
msgstr "Nintendo - Nintendo 64 (Mupen64Plus-Next)"

msgctxt "Addon Description"
msgid "Mupen64 is an N64 emulator desgined to be multi-OS. It uses a plugin system and is highly compatible."
msgstr "Mupen64 je emulátor N64 navržený pro více operačních systémů. Používá systém zásuvných modulů a má vysokou kompatibilitu."

