From 8af0c80320e73dd25043af1107866db8bd280d10 Mon Sep 17 00:00:00 2001
From: Garrett Brown <themagnificentmrb@gmail.com>
Date: Wed, 3 Sep 2025 16:59:04 -0700
Subject: [PATCH 4/7] Fix compiler error on Windows

Error was:

  libretro/libretro.c:469:17: error: implicit declaration of function 'rand_s'; did you mean 'rand'? [-Wimplicit-function-declaration]
    469 |                 rand_s(&reg_id);
        |                 ^~~~~~
        |                 rand
---
 libretro/libretro.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/libretro/libretro.c b/libretro/libretro.c
index 76656668..86e336f1 100644
--- a/libretro/libretro.c
+++ b/libretro/libretro.c
@@ -19,6 +19,9 @@
  * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * */
 
 #include <stdio.h>
+#ifdef __MINGW32__
+#define _CRT_RAND_S
+#endif
 #include <stdlib.h>
 #include <string.h>
 #include <compat/strl.h>
-- 
2.53.0

